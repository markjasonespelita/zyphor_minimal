#!/bin/sh
# =============================================================================
#  MyOS Installer
#  Supports: QEMU / VirtualBox / VMware + Real Hardware (BIOS + UEFI)
# =============================================================================

MOUNT="/mnt"

# -----------------------------------------------------------------------------
# Check required tools
# -----------------------------------------------------------------------------
for tool in fdisk mkfs.ext4 mount cp lsblk; do
    if ! command -v "$tool" > /dev/null 2>&1; then
        echo "[ERROR] Missing required tool: $tool"
        exit 1
    fi
done

# -----------------------------------------------------------------------------
# Auto-detect disk
# -----------------------------------------------------------------------------
echo "[MyOS] Detecting available disks..."
lsblk -d -o NAME,SIZE,TYPE | grep disk

echo ""
printf "Enter disk to install to (e.g. sda, nvme0n1, vda): /dev/"
read DISKNAME
DISK="/dev/$DISKNAME"

# Handle NVMe / eMMC partition naming (nvme0n1 -> nvme0n1p1)
case "$DISK" in
    *nvme*|*mmcblk*) PART="${DISK}p1" ;;
    *)               PART="${DISK}1"  ;;
esac

echo "[MyOS] Selected disk : $DISK"
echo "[MyOS] Partition     : $PART"

# -----------------------------------------------------------------------------
# Check disk exists
# -----------------------------------------------------------------------------
if [ ! -b "$DISK" ]; then
    echo "[ERROR] Disk $DISK not found."
    exit 1
fi

# -----------------------------------------------------------------------------
# Safety check — make sure /mnt is free
# -----------------------------------------------------------------------------
if mountpoint -q "$MOUNT"; then
    echo "[ERROR] $MOUNT is already mounted. Unmount it first."
    exit 1
fi

# -----------------------------------------------------------------------------
# Detect BIOS or UEFI
# -----------------------------------------------------------------------------
if [ -d /sys/firmware/efi ]; then
    BOOT_MODE="uefi"
    echo "[MyOS] Boot mode: UEFI"
else
    BOOT_MODE="bios"
    echo "[MyOS] Boot mode: BIOS/Legacy"
fi

# -----------------------------------------------------------------------------
# Confirm
# -----------------------------------------------------------------------------
echo ""
echo "======================================"
echo "  WARNING: This will ERASE $DISK"
echo "  Partition : $PART"
echo "  Boot mode : $BOOT_MODE"
echo "======================================"
printf "Type YES to continue: "
read confirm
[ "$confirm" != "YES" ] && echo "Aborted." && exit 1

# -----------------------------------------------------------------------------
# 1. Partition
# -----------------------------------------------------------------------------
echo "[1/8] Partitioning $DISK..."

if [ "$BOOT_MODE" = "uefi" ]; then
    # GPT: EFI partition (512M) + root partition (rest)
    printf "g\nn\n1\n\n+512M\nt\n1\nn\n2\n\n\nw\n" | fdisk "$DISK"
    case "$DISK" in
        *nvme*|*mmcblk*) EFI_PART="${DISK}p1" ; PART="${DISK}p2" ;;
        *)               EFI_PART="${DISK}1"  ; PART="${DISK}2"  ;;
    esac
else
    # MBR: single bootable root partition
    printf "o\nn\np\n1\n\n\na\nw\n" | fdisk "$DISK"
fi

sleep 2

# -----------------------------------------------------------------------------
# 2. Format
# -----------------------------------------------------------------------------
echo "[2/8] Formatting partitions..."

if [ "$BOOT_MODE" = "uefi" ]; then
    mkfs.fat -F32 "$EFI_PART"
    echo "[MyOS] Formatted EFI partition : $EFI_PART"
fi

mkfs.ext4 -F -L "MyOS" "$PART"
echo "[MyOS] Formatted root partition: $PART"

# -----------------------------------------------------------------------------
# 3. Mount
# -----------------------------------------------------------------------------
echo "[3/8] Mounting..."
mkdir -p "$MOUNT"
mount "$PART" "$MOUNT"

if [ "$BOOT_MODE" = "uefi" ]; then
    mkdir -p "$MOUNT/boot/efi"
    mount "$EFI_PART" "$MOUNT/boot/efi"
fi

# -----------------------------------------------------------------------------
# 4. Copy rootfs
# -----------------------------------------------------------------------------
echo "[4/8] Copying system files..."
for dir in bin sbin usr lib lib64 etc root home var; do
    if [ -d "/$dir" ]; then
        echo "  Copying /$dir..."
        cp -a "/$dir" "$MOUNT/"
    fi
done

# Create essential mountpoints
mkdir -p "$MOUNT/proc"
mkdir -p "$MOUNT/sys"
mkdir -p "$MOUNT/dev"
mkdir -p "$MOUNT/run"
mkdir -p "$MOUNT/mnt"
mkdir -p "$MOUNT/tmp"
chmod 1777 "$MOUNT/tmp"

# Copy kernel and initramfs
mkdir -p "$MOUNT/boot"
[ -f /boot/vmlinuz ]   && cp /boot/vmlinuz   "$MOUNT/boot/"
[ -f /boot/initramfs ] && cp /boot/initramfs "$MOUNT/boot/"

# -----------------------------------------------------------------------------
# 5. Create /sbin/init on installed system
# -----------------------------------------------------------------------------
echo "[5/8] Creating /sbin/init..."
mkdir -p "$MOUNT/sbin"
cat > "$MOUNT/sbin/init" << 'INIT'
#!/bin/sh
# =============================================================================
#  MyOS /sbin/init  —  Installed system init (runs after switch_root)
# =============================================================================
export PATH=/bin:/sbin:/usr/bin:/usr/sbin

# Mount essential pseudo-filesystems
mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev 2>/dev/null
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts

# Safety fallback: ensure critical device nodes exist
[ ! -e /dev/console ] && mknod -m 600 /dev/console c 5 1
[ ! -e /dev/null ]    && mknod -m 666 /dev/null    c 1 3
[ ! -e /dev/tty ]     && mknod -m 666 /dev/tty     c 5 0

# Mount /run as tmpfs — required by dhcpcd, udev, and others
mount -t tmpfs tmpfs /run
mkdir -p /run/dhcpcd
mkdir -p /run/lock
mkdir -p /run/udev

# Enable sysrq — allows reboot/poweroff via /proc/sysrq-trigger
echo 1 > /proc/sys/kernel/sysrq

# Set hostname
hostname MyOS

# Bring up loopback
ip link set lo up 2>/dev/null

# Bring up ethernet — try common interface names
for iface in eth0 ens3 ens33 enp0s3 enp1s0; do
    if ip link show "$iface" > /dev/null 2>&1; then
        echo "[MyOS] Bringing up $iface..."
        ip link set "$iface" up
        dhcpcd "$iface" &
        break
    fi
done

# Set root password
echo "root:root" | chpasswd 2>/dev/null

# Login banner
cat > /etc/issue << 'ISSUE'
====================================
        Welcome to MyOS
====================================
ISSUE

# Boot message
clear
echo "======================================"
echo "         MyOS Minimal OS"
echo "======================================"
echo " Kernel: $(uname -r)"
echo " Date  : $(date)"
echo "======================================"
echo ""
echo "[MyOS] System ready."
echo ""

# Login loop — PID 1 never exits
while true; do
    /bin/login
    echo ""
    echo "[MyOS] Session ended. Restarting login..."
    echo ""
    sleep 1
done
INIT
chmod +x "$MOUNT/sbin/init"

# -----------------------------------------------------------------------------
# 6. Create reboot / poweroff / shutdown commands
# -----------------------------------------------------------------------------
echo "[6/8] Creating reboot/poweroff commands..."

cat > "$MOUNT/bin/reboot" << 'EOF'
#!/bin/sh
echo "[MyOS] Rebooting..."
sync
echo b > /proc/sysrq-trigger
EOF
chmod +x "$MOUNT/bin/reboot"

cat > "$MOUNT/bin/poweroff" << 'EOF'
#!/bin/sh
echo "[MyOS] Powering off..."
sync
echo o > /proc/sysrq-trigger
EOF
chmod +x "$MOUNT/bin/poweroff"

# Alias shutdown to poweroff
ln -sf /bin/poweroff "$MOUNT/bin/shutdown"

# -----------------------------------------------------------------------------
# 7. Install GRUB
# -----------------------------------------------------------------------------
echo "[7/8] Installing GRUB..."

if command -v grub-install > /dev/null 2>&1; then
    if [ "$BOOT_MODE" = "uefi" ]; then
        grub-install \
            --target=x86_64-efi \
            --efi-directory="$MOUNT/boot/efi" \
            --boot-directory="$MOUNT/boot" \
            --removable \
            --recheck \
            "$DISK"
    else
        grub-install \
            --target=i386-pc \
            --boot-directory="$MOUNT/boot" \
            --recheck \
            "$DISK"
    fi
else
    echo "[WARN] grub-install not found — skipping GRUB installation."
fi

# -----------------------------------------------------------------------------
# 8. Write GRUB config
# -----------------------------------------------------------------------------
echo "[8/8] Writing GRUB config..."
mkdir -p "$MOUNT/boot/grub"
cat > "$MOUNT/boot/grub/grub.cfg" << GRUBCFG
set timeout=3
set default=0

menuentry "MyOS" {
    linux  /boot/vmlinuz root=$PART rw quiet
    initrd /boot/initramfs
}
GRUBCFG

# -----------------------------------------------------------------------------
# Done — unmount cleanly
# -----------------------------------------------------------------------------
sync

if [ "$BOOT_MODE" = "uefi" ]; then
    umount "$MOUNT/boot/efi"
fi
umount "$MOUNT"

echo ""
echo "======================================"
echo "  Installation complete!"
echo "  Reboot and remove install media."
echo "======================================"
