#!/bin/sh
# =============================================================================
#  MyOS /init  —  PID 1 entry point (initramfs)
#  Supports: QEMU / VirtualBox / VMware + Real Hardware (SATA/NVMe/eMMC)
# =============================================================================

# -----------------------------------------------------------------------------
# OS Identity Variables
# -----------------------------------------------------------------------------
OS_NAME="MyOS"
OS_FIRST="My"
OS_SECOND="Operating System"
OS_HOSTNAME="MyOS"

export PATH=/bin:/sbin:/usr/bin:/usr/sbin

# -----------------------------------------------------------------------------
# 1. Mount essential pseudo-filesystems
# -----------------------------------------------------------------------------
mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev 2>/dev/null || mdev -s 2>/dev/null
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts

[ ! -e /dev/console ] && mknod -m 600 /dev/console c 5 1
[ ! -e /dev/null ]    && mknod -m 666 /dev/null    c 1 3
[ ! -e /dev/tty ]     && mknod -m 666 /dev/tty     c 5 0

mount -t tmpfs tmpfs /run
mkdir -p /run/dhcpcd
mkdir -p /run/lock
mkdir -p /run/udev

echo 1 > /proc/sys/kernel/sysrq

# -----------------------------------------------------------------------------
# 2. Redirect stdio to console
# -----------------------------------------------------------------------------
exec 0</dev/console
exec 1>/dev/console
exec 2>/dev/console

# -----------------------------------------------------------------------------
# 3. Install lolcat + figlet if missing (live environment)
# -----------------------------------------------------------------------------
install_banner_tools() {
    command -v figlet  > /dev/null 2>&1 && \
    command -v lolcat  > /dev/null 2>&1 && return 0

    if command -v apk > /dev/null 2>&1; then
        apk add --no-cache figlet lolcat > /dev/null 2>&1
    elif command -v apt-get > /dev/null 2>&1; then
        apt-get install -y figlet lolcat > /dev/null 2>&1
    fi
}
install_banner_tools

# -----------------------------------------------------------------------------
# 4. Banner helper
# -----------------------------------------------------------------------------
show_live_banner() {
    clear
    if command -v figlet > /dev/null 2>&1 && command -v lolcat > /dev/null 2>&1; then
        figlet -f slant "$OS_FIRST" | lolcat
        figlet -f small " $OS_SECOND  //  Live" | lolcat
        printf "\n"
        printf "  Kernel : %s\n" "$(uname -r)"          | lolcat
        printf "  Date   : %s\n" "$(date '+%F  %T')"    | lolcat
        printf "  Host   : %s\n" "$OS_NAME"              | lolcat
        printf "\n"
        printf "  * To install %s : sh /install\n" "$OS_NAME" | lolcat
        printf "  * Changes here are NOT persistent\n"         | lolcat
        printf "\n"
    else
        echo "======================================"
        echo "         $OS_NAME Live Mode"
        echo "======================================"
        echo " Kernel: $(uname -r)"
        echo " Date  : $(date)"
        echo "======================================"
        echo ""
        echo " - To install $OS_NAME, type: sh /install"
        echo " - Changes here are NOT persistent"
        echo "======================================"
        echo ""
    fi
}

# -----------------------------------------------------------------------------
# 5. Detect root partition
# -----------------------------------------------------------------------------
ROOT=""

for param in $(cat /proc/cmdline); do
    case "$param" in
        root=*) ROOT="${param#root=}" ;;
    esac
done

if [ -z "$ROOT" ]; then
    echo "[$OS_NAME] No root= in cmdline. Auto-detecting disk..."
    for dev in \
        /dev/sda1 /dev/sda2 \
        /dev/sdb1 \
        /dev/nvme0n1p1 /dev/nvme0n1p2 \
        /dev/nvme1n1p1 \
        /dev/vda1 /dev/vda2 \
        /dev/mmcblk0p1 /dev/mmcblk0p2; do
        if [ -b "$dev" ]; then
            ROOT="$dev"
            echo "[$OS_NAME] Found disk: $ROOT"
            break
        fi
    done
fi

if [ -z "$ROOT" ]; then
    echo "[WARN] Could not detect any disk. Starting live mode..."
fi

# -----------------------------------------------------------------------------
# 6. Wait for disk to be ready
# -----------------------------------------------------------------------------
if [ -n "$ROOT" ]; then
    echo "[$OS_NAME] Waiting for $ROOT..."
    TRIES=0
    while [ ! -b "$ROOT" ]; do
        sleep 1
        TRIES=$((TRIES + 1))
        if [ "$TRIES" -ge 10 ]; then
            echo "[WARN] $ROOT not ready after 10 seconds. Starting live mode..."
            ROOT=""
            break
        fi
    done
fi

# -----------------------------------------------------------------------------
# 7. Boot installed system or fall back to live mode
# -----------------------------------------------------------------------------
mkdir -p /mnt/root

if [ -n "$ROOT" ] && mount -t ext4 "$ROOT" /mnt/root 2>/dev/null; then
    if [ -f /mnt/root/sbin/init ]; then
        echo "[$OS_NAME] Found installed system on $ROOT. Booting..."
        exec switch_root /mnt/root /sbin/init
        echo "[ERROR] switch_root failed! Falling back to live mode..."
        umount /mnt/root 2>/dev/null
    else
        echo "[WARN] /sbin/init not found on $ROOT. Starting live mode..."
        umount /mnt/root
    fi
else
    echo "[WARN] Could not mount $ROOT. Starting live mode..."
fi

# -----------------------------------------------------------------------------
# 8. Live mode setup
# -----------------------------------------------------------------------------
hostname "$OS_HOSTNAME"
echo "root:root" | chpasswd 2>/dev/null

ip link set lo up 2>/dev/null

for iface in eth0 ens3 ens33 enp0s3 enp1s0; do
    if ip link show "$iface" > /dev/null 2>&1; then
        echo "[$OS_NAME] Bringing up $iface..."
        ip link set "$iface" up
        dhcpcd "$iface" &
        break
    fi
done

show_live_banner

# -----------------------------------------------------------------------------
# 9. Live mode login loop — PID 1 never exits
# -----------------------------------------------------------------------------
while true; do
    /bin/login
    echo ""
    show_live_banner
    sleep 1
done